<UserControl x:Class="WindowLayoutManager.ToolWindows.LayoutWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="280"
             Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WindowLayoutManager;component/Styles/LayoutStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Save the current working context as a new named layout: type a name, press Enter. -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <TextBox x:Name="NameTextBox" KeyDown="NameTextBox_KeyDown"
                     ToolTip="Capture the open documents, view state, and breakpoints as a new named layout"/>
            <TextBlock Text="Type a name and press Enter to save"
                       IsHitTestVisible="False" Margin="5,3,0,0"
                       Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarTextInactiveBrushKey}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarTextInactiveBrushKey}}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=NameTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Saved layouts for the active solution. Double-click (or Enter) applies;
             right-click shows the VSCT-defined context menu (Apply / Rename / Delete).
             Rename swaps the label for an in-place TextBox (Enter commits, Esc cancels). -->
        <ListBox Grid.Row="1" x:Name="SnapshotList"
                 MouseDoubleClick="SnapshotList_MouseDoubleClick"
                 KeyDown="SnapshotList_KeyDown"
                 PreviewMouseRightButtonDown="SnapshotList_PreviewMouseRightButtonDown"
                 MouseRightButtonUp="SnapshotList_MouseRightButtonUp">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <TextBlock Text="{Binding Name}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding Name, Mode=OneWay}" Margin="-2,-1"
                                 Loaded="EditBox_Loaded"
                                 KeyDown="EditBox_KeyDown"
                                 LostKeyboardFocus="EditBox_LostKeyboardFocus">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2" x:Name="StatusText" Margin="0,6,0,0" TextWrapping="Wrap" FontSize="11"
                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarTextInactiveBrushKey}}"/>
    </Grid>
</UserControl>
